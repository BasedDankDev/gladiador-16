generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  brand       String      @default("GLADIADOR 16")
  price       Int
  image       String
  images      String?
  badge       String?
  variants    String?
  category    String      @default("general")
  inStock     Boolean     @default(true)
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
}

model Order {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  status           String      @default("pendiente")
  total            Int
  shippingName     String
  shippingLastName String      @default("")
  shippingPhone    String
  shippingEmail    String      @default("")
  shippingAddress  String
  shippingAddress2 String?
  shippingCity     String?
  shippingProvince String?
  shippingMethod   String      @default("envio")
  shippingCost     Int         @default(0)
  paymentMethod    String      @default("transferencia")
  sinpeRef         String?
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  items            OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int
  size      String?
  color     String?
}
